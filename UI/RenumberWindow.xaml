<Window
    x:Class="Renumber.UI.RenumberWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Renumber"
    xmlns:ui="clr-namespace:Renumber.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Renumber"
    Width="280"
    Height="580"
    MinWidth="190"
    MinHeight="480"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove"
    PreviewKeyDown="Window_PreviewKeyDown"
    PreviewKeyUp="Window_PreviewKeyUp"
    mc:Ignorable="av">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#FF1F1F1F" />
                    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FF292929" />
                    <SolidColorBrush x:Key="BorderBrush" Color="#FF444444" />
                    <SolidColorBrush x:Key="ForegroundBrush" Color="#EEEEEE" />
                    <ui:InverseBooleanConverter x:Key="InverseBoolConverter" />
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Renumber;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">
        <!-- Outer Border with Opacity and Blur -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!-- Content Container -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="10">
            <Grid x:Name="MainContentGrid" PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" /> <!-- Title bar -->
                    <RowDefinition Height="*" />  <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Title bar (Row 0) -->
                <ui:TitleBar
                    Grid.Row="0"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded" />

                <!-- Theme toggle -->
                <ToggleButton
                    x:Name="ThemeToggleButton"
                    Grid.Row="0"
                    Width="28"
                    Height="15.5"
                    Margin="0,0,70,0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="ToggleTheme_Click"
                    IsChecked="True"
                    ToolTip="Toggle Theme">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Grid Background="Transparent">
                                <materialDesign:PackIcon
                                    x:Name="ThemeToggleIcon"
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource IconBrush}"
                                    Kind="ToggleSwitchOffOutline" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOffOutline" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOutline" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- Main Form Content (Row 1) -->
                <Grid Grid.Row="1" Margin="16,8,16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Mode selector -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />     <!-- Mode-specific panels -->
                    </Grid.RowDefinitions>

                    <!-- Mode selector: EL / LPS / Üld -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ElModeCheck"
                                  Content="EL"
                                  IsChecked="True"
                                  Checked="ElModeCheck_Checked"
                                  Style="{StaticResource CustomCheckboxStyleCompact}"
                                  Margin="0,0,20,0" />
                        <CheckBox x:Name="LpsModeCheck"
                                  Content="LPS"
                                  IsChecked="False"
                                  Checked="LpsModeCheck_Checked"
                                  Style="{StaticResource CustomCheckboxStyleCompact}"
                                  Margin="0,0,20,0" />
                        <CheckBox x:Name="UldModeCheck"
                                  Content="Üld"
                                  IsChecked="False"
                                  Checked="UldModeCheck_Checked"
                                  Style="{StaticResource CustomCheckboxStyleCompact}"
                                  Margin="0,0,20,0" />
                        <CheckBox x:Name="HeliModeCheck"
                                  Content="Heli"
                                  IsChecked="False"
                                  Checked="HeliModeCheck_Checked"
                                  Style="{StaticResource CustomCheckboxStyleCompact}"
                                  Margin="0,0,20,0" />
                        <CheckBox x:Name="AtsModeCheck"
                                  Content="ATS"
                                  IsChecked="False"
                                  Checked="AtsModeCheck_Checked"
                                  Style="{StaticResource CustomCheckboxStyleCompact}" />
                    </StackPanel>

                    <!-- ============================================================
                         EL Panel (existing functionality)
                    ============================================================ -->
                    <Grid x:Name="ElPanel" Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Parameter Name label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name TextBox -->
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />  <!-- Value label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Value TextBox -->
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />  <!-- Button -->
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />     <!-- Result text -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Parameter Name"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <TextBox Grid.Row="2"
                                 x:Name="ParameterNameBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Value"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ElDirectionUpCheck"
                                          Content="↑"
                                          IsChecked="True"
                                          Checked="ElDirectionUpCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="ElDirectionDownCheck"
                                          Content="↓"
                                          IsChecked="False"
                                          Checked="ElDirectionDownCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="ElFreezeCheck"
                                          Content="="
                                          IsChecked="False"
                                          Checked="ElFreezeCheck_Checked"
                                          Unchecked="ElFreezeCheck_Unchecked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          ToolTip="Freeze: apply the same value to every pick without incrementing" />
                            </StackPanel>
                        </Grid>

                        <TextBox Grid.Row="6"
                                 x:Name="ValueBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <Button Grid.Row="8"
                                x:Name="SelectButton"
                                Content="Select Electrical Fixtures"
                                Click="SelectButton_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="Auto"
                                HorizontalAlignment="Stretch"
                                Height="34" />

                        <ScrollViewer Grid.Row="10" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ResultText"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       Opacity="0.85" />
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================================================
                         LPS Panel
                    ============================================================ -->
                    <Grid x:Name="LpsPanel" Grid.Row="2" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Parameters label + Add button -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" MaxHeight="160" />  <!-- Param list -->
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />  <!-- Value label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Value TextBox -->
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />  <!-- Select button -->
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />     <!-- Result text -->
                        </Grid.RowDefinitions>

                        <!-- Parameters label + Add button -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Parameters"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    x:Name="LpsAddParamButton"
                                    Content="+"
                                    Click="LpsAddParam_Click"
                                    Style="{StaticResource CustomActionButtonStyle}"
                                    Width="32" Height="24"
                                    Padding="0"
                                    FontSize="16" FontWeight="Bold" />
                        </Grid>

                        <!-- Parameter row list -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="LpsParamList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />  <!-- Active CB -->
                                                <ColumnDefinition Width="*" />     <!-- Name TextBox -->
                                                <ColumnDefinition Width="Auto" />  <!-- Value CB -->
                                                <ColumnDefinition Width="Auto" />  <!-- InnerRange CB -->
                                                <ColumnDefinition Width="Auto" />  <!-- Remove button -->
                                            </Grid.ColumnDefinitions>
                                            <!-- Active (left) checkbox -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Style="{StaticResource CustomCheckboxStyleCompact}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0" />
                                            <!-- Parameter name -->
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource CustomTextBoxStyle}"
                                                     Width="90"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center" />
                                            <!-- Value sequence checkbox (!UseInnerRange) -->
                                            <CheckBox Grid.Column="2"
                                                      Content="Value"
                                                      IsChecked="{Binding UseInnerRange, Mode=TwoWay,
                                                                  Converter={StaticResource InverseBoolConverter}}"
                                                      Style="{StaticResource CustomCheckboxStyleCompact}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,0,0" />
                                            <!-- InnerRange sequence checkbox -->
                                            <CheckBox Grid.Column="3"
                                                      Content="IR"
                                                      IsChecked="{Binding UseInnerRange, Mode=TwoWay}"
                                                      Style="{StaticResource CustomCheckboxStyleCompact}"
                                                      VerticalAlignment="Center"
                                                      Margin="4,0,0,0" />
                                            <!-- Remove button -->
                                            <Button Grid.Column="4"
                                                    Content="−"
                                                    Tag="{Binding}"
                                                    Click="LpsRemoveParam_Click"
                                                    Style="{StaticResource CustomActionButtonStyle}"
                                                    Width="28" Height="24"
                                                    Padding="0"
                                                    FontSize="14" FontWeight="Bold"
                                                    Margin="6,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Value label + direction -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Value"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="LpsDirectionUpCheck"
                                          Content="↑"
                                          IsChecked="True"
                                          Checked="LpsDirectionUpCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="LpsDirectionDownCheck"
                                          Content="↓"
                                          IsChecked="False"
                                          Checked="LpsDirectionDownCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="LpsFreezeCheck"
                                          Content="="
                                          IsChecked="False"
                                          Checked="LpsFreezeCheck_Checked"
                                          Unchecked="LpsFreezeCheck_Unchecked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          ToolTip="Freeze: apply the same value to every pick without incrementing" />
                            </StackPanel>
                        </Grid>

                        <!-- Value TextBox -->
                        <TextBox Grid.Row="6"
                                 x:Name="LpsValueBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Select button -->
                        <Button Grid.Row="8"
                                x:Name="LpsSelectButton"
                                Content="Select Security Devices"
                                Click="LpsSelectButton_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="Auto"
                                HorizontalAlignment="Stretch"
                                Height="34" />

                        <!-- Result text -->
                        <ScrollViewer Grid.Row="10" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LpsResultText"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       Opacity="0.85" />
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================================================
                         Üld Panel (general category parameter write)
                    ============================================================ -->
                    <Grid x:Name="UldPanel" Grid.Row="2" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Category label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Category ComboBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name TextBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Value label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Value TextBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Prefix / Suffix row -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Select button -->
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />     <!-- Result text -->
                        </Grid.RowDefinitions>

                        <!-- Category label -->
                        <TextBlock Grid.Row="0"
                                   Text="Category"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Category ComboBox -->
                        <ComboBox Grid.Row="2"
                                  x:Name="UldCategoryCombo"
                                  Style="{StaticResource DarkThemeComboBox}"
                                  SelectionChanged="UldCategoryCombo_SelectionChanged"
                                  HorizontalAlignment="Stretch" />

                        <!-- Parameter Name label -->
                        <TextBlock Grid.Row="4"
                                   x:Name="UldParamNameLabel"
                                   Text="Parameter Name"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Parameter Name TextBox -->
                        <TextBox Grid.Row="6"
                                 x:Name="UldParamNameBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Value label + direction -->
                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Value"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="UldDirectionUpCheck"
                                          Content="↑"
                                          IsChecked="True"
                                          Checked="UldDirectionUpCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="UldDirectionDownCheck"
                                          Content="↓"
                                          IsChecked="False"
                                          Checked="UldDirectionDownCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="UldFreezeCheck"
                                          Content="="
                                          IsChecked="False"
                                          Checked="UldFreezeCheck_Checked"
                                          Unchecked="UldFreezeCheck_Unchecked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          ToolTip="Freeze: apply the same value to every pick without incrementing" />
                            </StackPanel>
                        </Grid>

                        <!-- Value TextBox -->
                        <TextBox Grid.Row="10"
                                 x:Name="UldValueBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Prefix / Suffix row -->
                        <Grid Grid.Row="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Prefix"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBox x:Name="UldPrefixBox"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Suffix"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBox x:Name="UldSuffixBox"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>

                        <!-- Select button -->
                        <Button Grid.Row="14"
                                x:Name="UldSelectButton"
                                Content="Select Elements"
                                Click="UldSelectButton_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="Auto"
                                HorizontalAlignment="Stretch"
                                Height="34" />

                        <!-- Result text -->
                        <ScrollViewer Grid.Row="16" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="UldResultText"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       Opacity="0.85" />
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================================================
                         Heli Panel (alternating value write)
                    ============================================================ -->
                    <Grid x:Name="HeliPanel" Grid.Row="2" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Category label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Category ComboBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name TextBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Value 1 label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Value 1 TextBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Value 2 label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Value 2 TextBox -->
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />  <!-- Select button -->
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />     <!-- Result text -->
                        </Grid.RowDefinitions>

                        <!-- Category label -->
                        <TextBlock Grid.Row="0"
                                   Text="Category"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Category ComboBox -->
                        <ComboBox Grid.Row="2"
                                  x:Name="HeliCategoryCombo"
                                  Style="{StaticResource DarkThemeComboBox}"
                                  SelectionChanged="HeliCategoryCombo_SelectionChanged"
                                  HorizontalAlignment="Stretch" />

                        <!-- Parameter Name label -->
                        <TextBlock Grid.Row="4"
                                   Text="Parameter Name"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Parameter Name TextBox -->
                        <TextBox Grid.Row="6"
                                 x:Name="HeliParamNameBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Value 1 label -->
                        <TextBlock Grid.Row="8"
                                   Text="Value 1"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Value 1 TextBox -->
                        <TextBox Grid.Row="10"
                                 x:Name="HeliValue1Box"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Value 2 label -->
                        <TextBlock Grid.Row="12"
                                   Text="Value 2"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Value 2 TextBox -->
                        <TextBox Grid.Row="14"
                                 x:Name="HeliValue2Box"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Select button -->
                        <Button Grid.Row="16"
                                x:Name="HeliSelectButton"
                                Content="Select Elements"
                                Click="HeliSelectButton_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="Auto"
                                HorizontalAlignment="Stretch"
                                Height="34" />

                        <!-- Result text -->
                        <ScrollViewer Grid.Row="18" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="HeliResultText"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       Opacity="0.85" />
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================================================
                         ATS Panel (padded numbering — same as Üld + char count)
                    ============================================================ -->
                    <Grid x:Name="AtsPanel" Grid.Row="2" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Category label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Category ComboBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name TextBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Value label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Value TextBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Char Count label -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Char Count TextBox -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Prefix / Suffix row -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name 2 toggle -->
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />  <!-- Parameter Name 2 + Fixed Value panel -->
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />  <!-- Select button -->
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />     <!-- Result text -->
                        </Grid.RowDefinitions>

                        <!-- Category label -->
                        <TextBlock Grid.Row="0"
                                   Text="Category"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Category ComboBox -->
                        <ComboBox Grid.Row="2"
                                  x:Name="AtsCategoryCombo"
                                  Style="{StaticResource DarkThemeComboBox}"
                                  SelectionChanged="AtsCategoryCombo_SelectionChanged"
                                  HorizontalAlignment="Stretch" />

                        <!-- Parameter Name label -->
                        <TextBlock Grid.Row="4"
                                   x:Name="AtsParamNameLabel"
                                   Text="Parameter Name"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <!-- Parameter Name TextBox -->
                        <TextBox Grid.Row="6"
                                 x:Name="AtsParamNameBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Value label + direction -->
                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Value"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="AtsDirectionUpCheck"
                                          Content="↑"
                                          IsChecked="True"
                                          Checked="AtsDirectionUpCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="AtsDirectionDownCheck"
                                          Content="↓"
                                          IsChecked="False"
                                          Checked="AtsDirectionDownCheck_Checked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          Margin="0,0,6,0" />
                                <CheckBox x:Name="AtsFreezeCheck"
                                          Content="="
                                          IsChecked="False"
                                          Checked="AtsFreezeCheck_Checked"
                                          Unchecked="AtsFreezeCheck_Unchecked"
                                          Style="{StaticResource CustomCheckboxStyleCompact}"
                                          ToolTip="Freeze: apply the same value to every pick without incrementing" />
                            </StackPanel>
                        </Grid>

                        <!-- Value TextBox -->
                        <TextBox Grid.Row="10"
                                 x:Name="AtsValueBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Char Count label -->
                        <TextBlock Grid.Row="12"
                                   Text="Char Count"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   ToolTip="Total character width of the number. The prefix character pads the left side to reach this width." />

                        <!-- Char Count TextBox -->
                        <TextBox Grid.Row="14"
                                 x:Name="AtsCharCountBox"
                                 Style="{StaticResource CustomTextBoxStyle}"
                                 HorizontalAlignment="Stretch" />

                        <!-- Prefix (fill char) / Suffix row -->
                        <Grid Grid.Row="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Prefix (fill char)"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,3"
                                           ToolTip="Single character used to left-pad the value to the Char Count width (e.g. '0' gives 001, 002 …)" />
                                <TextBox x:Name="AtsPrefixBox"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Suffix"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBox x:Name="AtsSuffixBox"
                                         Style="{StaticResource CustomTextBoxStyle}"
                                         HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>

                        <!-- Parameter Name 2 toggle header -->
                        <CheckBox Grid.Row="18"
                                  x:Name="AtsParam2EnabledCheck"
                                  Content="Parameter Name 2"
                                  IsChecked="False"
                                  Checked="AtsParam2EnabledCheck_Checked"
                                  Unchecked="AtsParam2EnabledCheck_Unchecked"
                                  Style="{StaticResource CustomCheckboxStyleCompact}"
                                  ToolTip="Enable a second parameter written with a fixed value on every pick." />

                        <!-- Parameter Name 2 + Fixed Value fields (collapsed when toggle is off) -->
                        <StackPanel Grid.Row="20"
                                    x:Name="AtsParam2Panel"
                                    Visibility="Collapsed">
                            <TextBox x:Name="AtsParamName2Box"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     HorizontalAlignment="Stretch" />
                            <TextBlock Text="Fixed Value"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Margin="0,8,0,3"
                                       ToolTip="Value written to Parameter Name 2 on every pick (does not increment)." />
                            <TextBox x:Name="AtsFixedValueBox"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- Select button -->
                        <Button Grid.Row="22"
                                x:Name="AtsSelectButton"
                                Content="Select Elements"
                                Click="AtsSelectButton_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="Auto"
                                HorizontalAlignment="Stretch"
                                Height="34" />

                        <!-- Result text -->
                        <ScrollViewer Grid.Row="24" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="AtsResultText"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       Opacity="0.85" />
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>
        </Border>

        <!-- Resize edges -->
        <Border x:Name="LeftEdge" Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseEnter="LeftEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown" />
        <Border x:Name="RightEdge" Width="9" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseEnter="RightEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="RightEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomEdge" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNS" Panel.ZIndex="3000"
                MouseEnter="BottomEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomLeftCorner" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNESW" Panel.ZIndex="3000"
                MouseEnter="BottomLeftCorner_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown" />
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE" Panel.ZIndex="3000"
                MouseEnter="BottomRightCorner_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown" />
    </Grid>
</Window>
