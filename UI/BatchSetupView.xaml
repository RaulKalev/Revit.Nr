<UserControl x:Class="Renumber.UI.BatchSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ui="clr-namespace:Renumber.UI"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource PrimaryBackgroundBrush}">

    <UserControl.Resources>
        <ui:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <ui:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Validation Banner -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Validation Banner (visible when settings are invalid) -->
        <Border Grid.Row="0" 
                Background="#44FF6600" 
                BorderBrush="#FF6600" 
                BorderThickness="0,0,0,1"
                Padding="10,6"
                Visibility="{Binding ValidationBanner, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="AlertCircleOutline" Grid.Column="0" 
                                         Width="18" Height="18" 
                                         Foreground="#FFCC00" 
                                         VerticalAlignment="Center" 
                                         Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" 
                           Text="{Binding ValidationBanner}" 
                           Foreground="{DynamicResource ForegroundBrush}" 
                           TextWrapping="Wrap" 
                           VerticalAlignment="Center"
                           FontSize="12"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,8,8,4">
            <Button Command="{Binding ReloadCommand}" 
                    Style="{DynamicResource CustomActionButtonStyle}" 
                    ToolTip="Reload types from the Revit model"
                    Height="32" Margin="0,0,6,0" Padding="10,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="Reload from Model" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding SaveCommand}" 
                    Style="{DynamicResource CustomActionButtonStyle}" 
                    ToolTip="Save edited values to Revit types"
                    Height="32" Margin="0,0,6,0" Padding="10,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="Save to Types" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="BatchSetupDataGrid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  Style="{DynamicResource CustomDataGridStyle}"
                  ColumnHeaderStyle="{DynamicResource MultiRowHeaderStyle}"
                  CellStyle="{DynamicResource ExcelLikeCellStyle}"
                  SelectionMode="Extended"
                  SelectionUnit="Cell"
                  AlternationCount="2"
                  RowStyle="{DynamicResource ExcelLikeRowStyle}"
                  RowHeight="24"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Background="{DynamicResource PrimaryBackgroundBrush}"
                  Margin="8,0,8,0"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <!-- Category (read-only) -->
                <DataGridTextColumn Header="Category" 
                                    Binding="{Binding Category}" 
                                    IsReadOnly="True"
                                    Width="120"/>

                <!-- Family (read-only) -->
                <DataGridTextColumn Header="Family" 
                                    Binding="{Binding FamilyName}" 
                                    IsReadOnly="True"
                                    Width="*"/>

                <!-- Type (read-only) -->
                <DataGridTextColumn Header="Type" 
                                    Binding="{Binding TypeName}" 
                                    IsReadOnly="True"
                                    Width="*"/>

                <!-- mA Load (editable) -->
                <DataGridTextColumn Header="mA Load" 
                                    Binding="{Binding Editable_mA_Load, UpdateSourceTrigger=LostFocus, StringFormat=N1}" 
                                    Width="90"/>

                <!-- Address Count (editable) -->
                <DataGridTextColumn Header="Addr Count" 
                                    Binding="{Binding Editable_AddressCount, UpdateSourceTrigger=LostFocus}" 
                                    Width="90"/>

                <!-- Status (read-only) -->
                <DataGridTextColumn Header="Status" 
                                    Binding="{Binding Status}" 
                                    IsReadOnly="True"
                                    Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="3" 
                Background="{DynamicResource SecondaryBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="{DynamicResource ForegroundBrush}" 
                       FontSize="12" 
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="4" 
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
              Background="#88000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" 
                             Width="200" Height="4" 
                             Foreground="#4CAF50"
                             Background="#333333"
                             BorderThickness="0"/>
                <TextBlock Text="Loading..." 
                           Foreground="{DynamicResource ForegroundBrush}" 
                           FontSize="14" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
